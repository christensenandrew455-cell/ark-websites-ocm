NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
# Set this to the replacement hosted backend origin when one is configured.
NEXT_PUBLIC_APP_URL=

# Firebase Admin service account values (server-only)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe test or live secret key (server-only)
STRIPE_SECRET_KEY=sk_test_your-key

# Optional pre-created Stripe prices. When omitted, ARK creates the billing catalog automatically.
STRIPE_SOLO_BASE_PRICE_ID=
STRIPE_SOLO_PRO_BASE_PRICE_ID=
STRIPE_BUSINESS_BASE_PRICE_ID=
STRIPE_SOLO_LEAD_PRICE_ID=
STRIPE_BUSINESS_LEAD_PRICE_ID=
STRIPE_SOLO_CONVERSATION_PRICE_ID=
STRIPE_BUSINESS_CONVERSATION_PRICE_ID=
STRIPE_BUSINESS_EMPLOYEE_PRICE_ID=

# Telnyx messaging uses each business's already-connected receptionist number.
# ARK sends directly through the Telnyx Messages API; no separate outbound messaging webhook is required.
TELNYX_API_KEY=KEY_your_telnyx_api_key

# Verify inbound Telnyx webhook events delivered through the existing receptionist connection.
# Use the Telnyx Ed25519 public key (base64 or PEM) and/or a secret used by the existing receptionist service.
TELNYX_PUBLIC_KEY=
ARK_MESSAGING_INBOUND_SECRET=

# Comma-separated Firebase Authentication emails allowed to switch businesses
ADMIN_EMAILS=owner@example.com
