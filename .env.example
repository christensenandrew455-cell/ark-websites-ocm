# Firebase Web SDK values (public; used by browser and APK WebView)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-web-app-id

# Hosted application origin. Keep this aligned with capacitor.config.json.
NEXT_PUBLIC_APP_URL=https://ark-websites-ocm.vercel.app

# Firebase Admin service account values (server-only)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Administrator access and ARK's internal customer workspace
ADMIN_EMAILS=owner@example.com
ARK_ADMIN_CLIENT_ID=ark-ocm

# Stripe (server-only)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_webhook_signing_secret

# Optional Stripe price IDs. Leave these unset to let ARK create and store the catalog automatically.
STRIPE_ACCOUNT_BASE_PRICE_ID=
STRIPE_ACCOUNT_CALL_PRICE_ID=
STRIPE_ACCOUNT_MESSAGE_PRICE_ID=
STRIPE_ACCOUNT_EMPLOYEE_PRICE_ID=

# Scheduled server workflows. Generate long random values and use matching values in GitHub Actions secrets.
CRON_SECRET=
OCM_REMINDER_SECRET=
BILLING_WORKFLOW_SECRET=

# Telnyx messaging
TELNYX_API_KEY=KEY_your_telnyx_api_key
TELNYX_PUBLIC_KEY=

# Optional fallback secret for inbound messaging requests that do not use Telnyx signature verification.
ARK_MESSAGING_INBOUND_SECRET=

# Android builds also require this GitHub Actions secret (not a Vercel environment variable):
# FIREBASE_ANDROID_GOOGLE_SERVICES_JSON = the complete google-services.json file contents
