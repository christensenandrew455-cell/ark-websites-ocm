{
	"appId": "com.arkwebsites.clientcenter",
	"appName": "ARK Client Center",
	"webDir": "mobile-shell",
	"appendUserAgent": " ARKClientCenter/1.2",
	"backgroundColor": "#f8fafc",
	"loggingBehavior": "debug",
	"server": {
		"url": "https://ark-websites-ocm.vercel.app",
		"androidScheme": "https",
		"iosScheme": "https",
		"cleartext": false,
		"errorPath": "offline.html"
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"sound",
				"alert",
				"banner",
				"list"
			]
		}
	},
	"ios": {
		"contentInset": "automatic",
		"backgroundColor": "#f8fafc"
	},
	"android": {
		"backgroundColor": "#f8fafc",
		"webContentsDebuggingEnabled": true
	},
	"packageClassList": [
		"ContactsPlugin",
		"PushNotificationsPlugin",
		"CapacitorCalendarPlugin"
	]
}
