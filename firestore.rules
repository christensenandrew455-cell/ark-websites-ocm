rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function ownsClient(clientId) {
      return signedIn() && request.auth.token.clientId == clientId;
    }

    match /accounts/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /businesses/{clientId} {
      allow get: if isAdmin() || ownsClient(clientId);
      allow list: if isAdmin();
      allow write: if false;
    }

    match /ocmClients/{clientId} {
      allow read, write: if isAdmin() || ownsClient(clientId);

      match /{document=**} {
        allow read, write: if isAdmin() || ownsClient(clientId);
      }
    }

    match /signupSessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
