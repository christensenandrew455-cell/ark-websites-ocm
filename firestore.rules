rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isActiveOwner(clientId) {
      return signedIn()
        && request.auth.token.role == "customer"
        && request.auth.token.clientId == clientId
        && (!('accountStatus' in request.auth.token) || request.auth.token.accountStatus == "active");
    }

    match /accounts/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /businesses/{clientId} {
      allow get: if isAdmin() || isActiveOwner(clientId);
      allow list: if isAdmin();
      allow write: if false;

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /businessNameRegistry/{nameKey} {
      allow read, write: if false;
    }

    match /connections/{clientId} {
      allow read, write: if false;
    }

    match /ocmClients/{clientId} {
      allow read, write: if isAdmin() || isActiveOwner(clientId);

      match /{document=**} {
        allow read, write: if isAdmin() || isActiveOwner(clientId);
      }
    }

    match /signupSessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
