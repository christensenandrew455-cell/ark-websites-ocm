{
  "appId": "com.arkwebsites.clientcenter",
  "appName": "ARK Client Center",
  "webDir": "mobile-shell",
  "appendUserAgent": " ARKClientCenter/1.1",
  "backgroundColor": "#f8fafc",
  "loggingBehavior": "debug",
  "server": {
    "url": "https://ark-websites-ocm.vercel.app",
    "androidScheme": "https",
    "cleartext": false,
    "errorPath": "offline.html"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["sound", "alert", "banner", "list"]
    }
  },
  "android": {
    "backgroundColor": "#f8fafc",
    "webContentsDebuggingEnabled": true
  }
}
